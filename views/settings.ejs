<%- include('header') %>

<div class="settings-page">
  <h1>Settings</h1>

  <form id="settings-form" onsubmit="saveSettings(event)">
    <div class="form-group">
      <label for="slack_webhook_url">Slack Webhook URL</label>
      <input type="url" id="slack_webhook_url" name="slack_webhook_url" placeholder="https://hooks.slack.com/services/...">
      <button type="button" class="btn btn-secondary btn-sm" onclick="testSlack()">Send Test Message</button>
      <span id="slack-test-result"></span>
    </div>

    <div class="form-group">
      <label for="cron_schedule">Check Schedule (cron expression)</label>
      <input type="text" id="cron_schedule" name="cron_schedule" placeholder="0 */4 * * *">
      <small class="help-text">Default: <code>0 */4 * * *</code> (every 4 hours). Use <code>*/5 * * * *</code> for every 5 minutes (testing).</small>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Settings</button>
    </div>
  </form>

  <div id="settings-message"></div>
</div>

<script>loadSettings();</script>

<%- include('footer') %>
